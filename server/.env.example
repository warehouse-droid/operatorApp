# Local server
PORT=3000
APP_BASE_URL=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mbbs_yard

# NetSuite OAuth 2.0
NETSUITE_ACCOUNT_ID=YOUR_ACCOUNT_ID
NETSUITE_CLIENT_ID=YOUR_CLIENT_ID
NETSUITE_CLIENT_SECRET=YOUR_CLIENT_SECRET
NETSUITE_REDIRECT_URI=http://localhost:3000/api/auth/netsuite/callback

# Use the URLs shown by your NetSuite account/integration setup.
# Examples often look like:
# https://ACCOUNT_ID.app.netsuite.com/app/login/oauth2/authorize.nl
# https://ACCOUNT_ID.suitetalk.api.netsuite.com/services/rest/auth/oauth2/v1/token
# https://ACCOUNT_ID.suitetalk.api.netsuite.com/services/rest
NETSUITE_AUTH_URL=https://YOUR_ACCOUNT_ID.app.netsuite.com/app/login/oauth2/authorize.nl
NETSUITE_TOKEN_URL=https://YOUR_ACCOUNT_ID.suitetalk.api.netsuite.com/services/rest/auth/oauth2/v1/token
NETSUITE_REST_BASE_URL=https://YOUR_ACCOUNT_ID.suitetalk.api.netsuite.com/services/rest

# NetSuite OAuth scopes. Adjust if your account requires different values.
NETSUITE_SCOPES=rest_webservices
